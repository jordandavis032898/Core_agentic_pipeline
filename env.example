# Agentic Router Environment Variables
# Copy this file to .env and fill in your values

# Required API Keys
OPENAI_API_KEY=your_openai_api_key_here
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# API Authentication (leave empty for dev mode, set for production)
API_KEY=

# Qdrant Configuration (for chatbot/RAG)
# For docker-compose: http://qdrant:6333
# For local: http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=policy_documents

# Model Configuration (optional - defaults shown)
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
EXTRACTOR_MODEL=gpt-4o-mini

# Retrieval Configuration (optional)
TOP_K=5

# Default Metadata (optional)
DEFAULT_AUTHOR=unknown
DEFAULT_COMPANY=unknown

# Parser Configuration (optional)
USE_MULTIMODAL=true
PARSING_INSTRUCTION=
