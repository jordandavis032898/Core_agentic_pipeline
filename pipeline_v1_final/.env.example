# OpenAI API Key (REQUIRED)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# LlamaParse (LlamaCloud) API Key (OPTIONAL but recommended)
# Get your API key from: https://cloud.llamaindex.ai
# Without this, PDF parsing will fail
LLAMAPARSE_API_KEY=your-llamaparse-api-key-here

# Qdrant Configuration (OPTIONAL - defaults shown)
# Defaults to localhost:6333 if not set
# If using Docker: QDRANT_HOST=localhost, QDRANT_PORT=6333
# If using remote Qdrant: set QDRANT_HOST and QDRANT_PORT accordingly
QDRANT_HOST=localhost
QDRANT_PORT=6333
